# SciGate Environment Variables
# Copy to .env and fill in your values

# ── Required ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# ── VCS Provider (github | gitea) ────────────────────────
VCS_PROVIDER=github
# GITEA_URL=http://localhost:3000
# GITEA_TOKEN=

# ── CI Provider (jenkins | woodpecker | gha) ─────────────
CI_PROVIDER=jenkins
# JENKINS_URL=
# JENKINS_USER=
# JENKINS_TOKEN=
# WOODPECKER_URL=
# WOODPECKER_TOKEN=

# ── Scoring ───────────────────────────────────────────────
SCIGATE_THRESHOLD=75

# ── Notifications ─────────────────────────────────────────
# Comma-separated: ntfy,mattermost
SCIGATE_NOTIFY_CHANNELS=
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=scigate
# MATTERMOST_WEBHOOK_URL=

# ── Webhooks ──────────────────────────────────────────────
# GITHUB_WEBHOOK_SECRET=

# ── Dashboard ─────────────────────────────────────────────
SCIGATE_DASHBOARD_URL=http://localhost:8000

# ── Observability (docker compose --profile observability)─
GRAFANA_PASSWORD=scigate
